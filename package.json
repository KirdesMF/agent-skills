{
  "type": "module",
  "private": true,
  "packageManager": "bun@1.3.11",
  "scripts": {
    "lint": "oxlint . --disable-nested-config --ignore-pattern '**/vendor/**' --ignore-pattern '**/sources/**' --ignore-pattern '**/skills/**'",
    "format": "oxfmt . '!**/vendor/**' '!**/sources/**' '!**/skills/**'",
    "format:check": "oxfmt --check . '!**/vendor/**' '!**/sources/**' '!**/skills/**'",
    "start": "node scripts/cli.ts",
    "prepare": "simple-git-hooks"
  },
  "devDependencies": {
    "@clack/prompts": "^1.1.0",
    "@types/node": "^25.5.0",
    "lint-staged": "^16.3.3",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^5.9.3"
  },
  "simple-git-hooks": {
    "pre-commit": "bun lint-staged"
  },
  "lint-staged": {
    "*.{js,ts,mjs,mts}": [
      "oxfmt --write",
      "oxlint --fix"
    ]
  }
}
